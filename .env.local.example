# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# (Supabase > Project Settings > API)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Necessária pro feed de agenda (.ics) e pro cron de notificações — Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Token que você mesmo inventa pra proteger o link da agenda (/api/agenda?token=...)
CALENDAR_FEED_TOKEN=um-codigo-aleatorio-qualquer

# UUID do seu usuário no Supabase (Authentication > Users) — o feed da agenda só mostra
# clientes desse user_id, pra não vazar dados de outros usuários quando o app virar multiusuário
AGENDA_USER_ID=uuid-do-seu-usuario-aqui

# Chaves de notificação push — gere rodando: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=sua-vapid-public-key-aqui
VAPID_PRIVATE_KEY=sua-vapid-private-key-aqui

# Segredo que protege a rota do cron diário (invente um código aleatório)
CRON_SECRET=um-codigo-aleatorio-qualquer

# Chave da API da Anthropic pro assistente "Jarbas" — crie a sua em console.anthropic.com
# (é uma conta separada da sua assinatura do Claude, cobrada por uso)
ANTHROPIC_API_KEY=sua-chave-da-api-aqui

# Código que você compartilha com os colegas pra eles criarem a própria conta em /cadastro
# (invente uma palavra/código qualquer — sem ele, ninguém consegue se cadastrar)
SIGNUP_INVITE_CODE=um-codigo-que-so-voce-e-seus-colegas-sabem
